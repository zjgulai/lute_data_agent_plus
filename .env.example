# ============================================
# GMV 智能归因系统 - 环境变量模板
# ============================================
# 复制本文件为 .env 后填入实际值
# cp .env.example .env
# ============================================

# --------------------------------------------
# 后端配置
# --------------------------------------------

# 数据库连接字符串（Docker 部署时使用 PostgreSQL）
DATABASE_URL=postgresql://gmv_user:gmv_password@localhost:5432/gmv_attribution

# LLM 配置
LLM_PROVIDER=mock
LLM_MODEL=claude-3-opus-20240229
LLM_API_KEY=your-api-key-here
LLM_API_BASE=

# --------------------------------------------
# CORS 配置
# --------------------------------------------
# 多个域名用英文逗号分隔，不设置则开发模式通配 *
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 前端配置
# --------------------------------------------

# 后端 API 基地址（Vite 专用前缀 VITE_）
VITE_API_BASE_URL=http://localhost:8000/api/v1
